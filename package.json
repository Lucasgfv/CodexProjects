{
  "name": "autcompany",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "tsx --test tests/company-validation.test.ts tests/cnpj-card.test.ts tests/certificate-status.test.ts tests/password.test.ts tests/upload-validation.test.ts tests/permissions.test.ts",
    "test:ocr": "tsx --test tests/cnpj-ocr.test.ts",
    "verify": "pnpm test && pnpm exec tsc --noEmit && pnpm build",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:seed": "tsx prisma/seed.ts",
    "user:bootstrap": "tsx scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "1.0.2",
    "@prisma/client": "^6.10.0",
    "@tesseract.js-data/por": "1.0.0",
    "bcryptjs": "3.0.3",
    "lucide-react": "^0.468.0",
    "next": "^15.3.0",
    "next-auth": "5.0.0-beta.31",
    "pdfjs-dist": "~5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "7.0.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
